# Copy this file to .env and fill in real values:  cp .env.example .env

# MySQL connection string — format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://buguser:bugpassword@localhost:3307/bug_dash"

# Secret used to sign auth session tokens. Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-generated-secret"

# The base URL the app runs on in development
NEXTAUTH_URL="http://localhost:3000"
